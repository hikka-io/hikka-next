{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "incremental": true,
        "jsx": "react-jsx",
        "allowJs": true,
        "paths": {
            "@/features/*": ["./src/features/*"],
            "@/components/*": ["./src/components/*"],
            "@/utils/*": ["./src/utils/*"],
            "@/services/*": ["./src/services/*"],
            "@/types/*": ["./src/types/*"]
        }
    },
    "include": ["src", "vite.config.ts"],
    "exclude": ["node_modules", ".output", "dist"],
    "references": [
        { "path": "../../packages/client" },
        { "path": "../../packages/react" }
    ]
}
