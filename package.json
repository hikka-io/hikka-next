{
    "name": "hikka-monorepo",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "check": "biome check --write .",
        "check:ci": "biome check .",
        "typecheck": "turbo run typecheck",
        "clean": "turbo run clean",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "dev:web-start": "turbo run dev --filter=@hikka/web-start --host",
        "build:web-start": "turbo run build --filter=@hikka/web-start",
        "start:web-start": "turbo run start --filter=@hikka/web-start",
        "dev:client": "turbo run dev --filter=@hikka/client",
        "build:client": "turbo run build --filter=@hikka/client",
        "dev:react": "turbo run dev --filter=@hikka/react",
        "build:react": "turbo run build --filter=@hikka/react"
    },
    "packageManager": "yarn@4.5.3",
    "syncpack": {
        "filter": "^(?!@hikka).*",
        "semverRange": ""
    },
    "resolutions": {
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "react": "19.2.1",
        "react-dom": "19.2.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@csstools/postcss-oklab-function": "^5.0.4",
        "@tailwindcss/postcss": "^4.2.2",
        "@types/node": "20.9.0",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "jest": "^29.7.0",
        "postcss": "8.4.47",
        "rimraf": "^5.0.1",
        "tailwindcss": "^4.2.2",
        "ts-jest": "^29.1.2",
        "tsup": "^8.5.1",
        "turbo": "^2.9.18",
        "typescript": "5.7.2"
    },
    "dependencies": {
        "react-colorful": "^5.6.1"
    }
}
