{
    "name": "hikka-monorepo",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "prettier": "prettier \"*.{js,json,yml,md}\" \"packages/**/*\" \"apps/**/*\"",
        "format": "npm run prettier -- --write",
        "format:check": "npm run prettier -- --check",
        "lint": "eslint \"apps/**/*.{js,jsx,ts,tsx}\"",
        "lint:fix": "eslint \"apps/**/*.{js,jsx,ts,tsx}\" --fix",
        "clean": "turbo run clean",
        "dev": "turbo run dev",
        "build": "turbo run build",
        "dev:web-start": "turbo run dev --filter=@hikka/web-start",
        "build:web-start": "turbo run build --filter=@hikka/web-start",
        "start:web-start": "turbo run start --filter=@hikka/web-start",
        "dev:client": "turbo run dev --filter=@hikka/client",
        "build:client": "turbo run build --filter=@hikka/client",
        "dev:react": "turbo run dev --filter=@hikka/react",
        "build:react": "turbo run build --filter=@hikka/react"
    },
    "packageManager": "yarn@4.5.3",
    "syncpack": {
        "filter": "^(?!@hikka).*",
        "semverRange": ""
    },
    "resolutions": {
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "react": "19.2.1",
        "react-dom": "19.2.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "@tanstack/eslint-plugin-query": "^5.60.1",
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "@types/node": "20.9.0",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "^6.7.0",
        "@typescript-eslint/parser": "^6.7.0",
        "eslint": "^8.49.0",
        "eslint-config-next": "16.0.7",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-functional": "^6.0.0",
        "eslint-plugin-tailwindcss": "4.0.0-beta.0",
        "jest": "^29.7.0",
        "postcss": "8.4.47",
        "prettier": "^3.0.3",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "rimraf": "^5.0.1",
        "tailwindcss": "^4.2.2",
        "ts-jest": "^29.1.2",
        "tsup": "^8.5.1",
        "turbo": "^2.5.4",
        "typescript": "5.7.2"
    },
    "dependencies": {
        "react-colorful": "^5.6.1"
    }
}
