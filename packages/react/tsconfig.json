{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "sourceMap": true,
        "jsx": "react-jsx",
        "outDir": "./dist",
        "rootDir": ".",
        "paths": {
            "@hikka/client": ["../client/index.ts"],
            "@/client/*": ["./client/*"],
            "@/server/*": ["./server/*"],
            "@/core/*": ["./core/*"],
            "@/types/*": ["./types/*"],
            "@/core": ["./core/index.ts"],
            "@/client": ["./client/index.ts"],
            "@/server": ["./server/index.ts"],
            "@/types": ["./types/index.ts"],
            "@/utils": ["./utils/index.ts"],
            "@/options/*": ["./options/*"],
            "@/options": ["./options/index.ts"]
        }
    },
    "include": [
        "*.ts",
        "*.tsx",
        "**/*.ts",
        "**/*.tsx",
        "client/**/*",
        "server/**/*",
        "core/**/*",
        "types/**/*",
        "utils/**/*",
        "options/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx"
    ],
    "references": [{ "path": "../client" }]
}
