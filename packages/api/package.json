{
    "name": "@hikka/api",
    "version": "0.1.0",
    "description": "Generated TypeScript API layer for Hikka (client + TanStack Query)",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup --tsconfig tsconfig.build.json",
        "build:clean": "rimraf dist",
        "prebuild": "pnpm build:clean",
        "dev": "tsup --watch",
        "api:spec": "tsx scripts/sync-spec.ts",
        "api:generate": "openapi-ts",
        "test": "jest",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "typecheck": "tsc --noEmit --composite false"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "license": "MIT",
    "author": "olexh",
    "peerDependencies": {
        "@tanstack/react-query": "^5.101.1"
    },
    "dependencies": {
        "@hey-api/client-fetch": "^0.13.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "^0.99.0",
        "@types/jest": "^29.5.4",
        "@types/node": "20.9.0",
        "jest": "^29.6.4",
        "rimraf": "^5.0.1",
        "ts-jest": "^29.1.1",
        "tsup": "^8.4.0",
        "tsx": "^4.22.4",
        "typescript": "6.0.3"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node"
    }
}
