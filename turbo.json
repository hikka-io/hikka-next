{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalDependencies": ["**/.env.*local"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".output/**"]
        },
        "lint": {
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "test": {
            "dependsOn": ["^build"],
            "inputs": ["src/**", "vitest.config.ts", "vitest.setup.ts"]
        },
        "start": {
            "cache": false,
            "persistent": true
        },
        "api:spec": {
            "cache": false,
            "outputs": ["openapi.json"]
        },
        "api:generate": {
            "cache": false,
            "outputs": ["src/gen/**"]
        }
    }
}
